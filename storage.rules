rules_version = '2';

// 소유자 격리: users/{uid} 하위 이미지만 본인(uid)이 read/write. 그 외·미인증은 기본 deny.
// 경로 규약: users/{uid}/plants/{plantId}/{dxId}.jpg (design §3).
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
