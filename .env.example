# --- 외부 API 키 ---
OPENAI_API_KEY=
RDA_API_KEY=

# --- Gemini 인증: Vertex AI 모드 (권장 — GCP 크레딧 사용) ---
# 설정 시 GEMINI_API_KEY 무시됨. ADC 인증 필요: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=energy-ts-forecast
GOOGLE_CLOUD_LOCATION=asia-northeast1

# --- Gemini 인증: Google AI Studio 모드 (fallback — Vertex 미설정 시 사용) ---
# GEMINI_API_KEY=

# --- [인증 통합] Firebase ID 토큰 검증 (/compare·/trend 보호) ---
# 프론트 NEXT_PUBLIC_FIREBASE_PROJECT_ID와 동일한 Firebase 프로젝트 ID.
# (GOOGLE_CLOUD_PROJECT(Vertex)와 다를 수 있어 별도 지정.) 토큰 검증 자격은
# 기존 Vertex와 동일한 ADC 재사용: gcloud auth application-default login
FIREBASE_PROJECT_ID=
